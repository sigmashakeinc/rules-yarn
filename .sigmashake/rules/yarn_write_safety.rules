# yarn_write_safety.rules — Enforce safe package authoring for yarn projects.
# Technology: yarn | Capability: write
# Covers: lockfile, version pins, .yarnrc.yml auth tokens/plugins, resolutions.

rule no-edit-yarn-lockfile {
  enabled true
  priority 95
  severity error
  DENY write
  IF path EQUALS "yarn.lock"
  OR path ENDS_WITH "/yarn.lock"
  MESSAGE "yarn.lock must not be hand-edited. It is machine-generated by 'yarn install'. Manual edits corrupt integrity checksums and break reproducible installs."
}

rule no-caret-tilde-yarn {
  enabled true
  priority 85
  severity error
  DENY write
  IF path EQUALS "package.json" AND content LINE_REGEX "\"[\\^~][0-9]"
  OR path GLOB "**/package.json" AND content LINE_REGEX ": *\"[\\^~][0-9]"
  MESSAGE "Caret (^) and tilde (~) version ranges produce non-reproducible installs. Use exact version pins to ensure every 'yarn install' resolves identically."
}

rule no-yarnrc-authtoken {
  enabled true
  priority 95
  severity error
  DENY write
  IF path EQUALS ".yarnrc.yml" AND content LINE_REGEX "npmAuthToken\\s*:"
  OR path GLOB "**/.yarnrc.yml" AND content LINE_REGEX "npmAuthToken\\s*:"
  MESSAGE "Hardcoded npmAuthToken in .yarnrc.yml exposes registry credentials in source control. Use environment variable substitution: npmAuthToken: '${NPM_AUTH_TOKEN}'"
}

rule ask-yarnrc-plugins {
  enabled true
  priority 85
  severity warning
  ASK write
  IF path EQUALS ".yarnrc.yml" AND content CONTAINS "plugins:"
  OR path GLOB "**/.yarnrc.yml" AND content CONTAINS "plugins:"
  MESSAGE "Yarn plugins listed in .yarnrc.yml execute code during yarn operations. A malicious or compromised plugin can intercept installs, intercept publishes, or alter dependency resolution."
  PROMPT "Is each plugin from a trusted, verified source? Confirm the plugin checksums in .yarnrc.yml match the expected values and the plugin's source is audited."
}

rule ask-yarn-resolutions {
  enabled true
  priority 80
  severity warning
  ASK write
  IF path EQUALS "package.json" AND content CONTAINS "\"resolutions\""
  OR path GLOB "**/package.json" AND content CONTAINS "\"resolutions\""
  MESSAGE "yarn resolutions silently override transitive dependency versions across the entire dependency tree. Incorrect resolutions can mask security vulnerabilities or introduce incompatible versions."
  PROMPT "Is each resolution intentional and documented? Verify the resolved version is compatible with all packages that depend on it."
}
